rules_version = '2';

// =====================================================================
// Firestore Security Rules — Flotip (project: arcolasco)
// ---------------------------------------------------------------------
// Collezioni usate dall'app:
//   - users/{uid}            documenti profilo, ID == Auth UID
//                            campi: id, firstName, lastName, birthDate,
//                                   email, photoURL, bio, createdAt
//   - posts/{postId}         feed pubblico (tutti gli utenti loggati lo
//                            leggono)
//                            campi rilevanti: authorId
//   - libraryItems/{itemId}  libreria PRIVATA per utente
//                            campi rilevanti: ownerId, category
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------
    // users — ognuno legge tutti i profili (servono per autore dei post)
    //         ma scrive SOLO il proprio.
    // -----------------------------------------------------------------
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId;

      // -------------------------------------------------------------
      // users/{userId}/following/{otherId} — lista degli utenti che
      // {userId} segue. Idempotente: la presenza del documento implica
      // "userId segue otherId".
      // - read: tutti gli utenti loggati (per leggere stato follow di
      //   altri profili pubblici e contare followers/following).
      // - create / update / delete: SOLO l'utente proprietario (userId).
      // - create speciale: il recipient {otherId} può creare il doc
      //   quando sta accettando una propria richiesta di follow pending
      //   (esiste users/{otherId}/followRequests/{userId}). Questo è
      //   l'unico caso in cui un utente diverso da userId scrive nella
      //   sua subcollezione following — è gated dall'esistenza della
      //   request, quindi non si può "auto-promuoversi" follower a
      //   piacere.
      // -------------------------------------------------------------
      match /following/{otherId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null
                                      && request.auth.uid == userId;
        // Accept-flow: il recipient della richiesta crea il doc following
        // del requester. La rule pretende sia che il writer sia otherId
        // (cioè quello che sta venendo seguito) sia che esista una
        // followRequest pending da userId verso otherId.
        allow create: if request.auth != null
                      && request.auth.uid == otherId
                      && exists(/databases/$(database)/documents/users/$(otherId)/followRequests/$(userId));
      }

      // -------------------------------------------------------------
      // users/{userId}/followRequests/{requesterUid} — richieste di
      // follow ricevute da userId, ID del doc = uid del richiedente.
      // Payload: { requesterUid, requestedAt: Timestamp, status: "pending" }
      //
      // - read: il recipient (userId) e il requester possono leggere il
      //   proprio stato (serve per il bottone 3-stati su PublicProfile).
      // - create: SOLO il requester sul proprio doc, sul profilo di un
      //   altro utente (no self-follow request).
      // - delete: sia recipient (accept/reject) che requester (cancel).
      // - update: vietato — il payload è statico.
      //
      // L'effettiva creazione del doc following lato requester avviene
      // nella rule sopra (`match /following/{otherId}`), gated proprio
      // dall'esistenza di questa request.
      // -------------------------------------------------------------
      match /followRequests/{requesterUid} {
        allow read: if request.auth != null
                    && (request.auth.uid == userId
                        || request.auth.uid == requesterUid);
        allow create: if request.auth != null
                      && request.auth.uid == requesterUid
                      && request.auth.uid != userId
                      && request.resource.data.requesterUid == requesterUid;
        allow delete: if request.auth != null
                      && (request.auth.uid == userId
                          || request.auth.uid == requesterUid);
        allow update: if false;
      }

      // -------------------------------------------------------------
      // users/{userId}/fcmTokens/{tokenId} — token FCM dei device
      // dell'utente. Visibili e scrivibili SOLO dall'utente stesso.
      // Le Cloud Functions (admin SDK) bypassano queste rules e leggono
      // i token per inviare push.
      // -------------------------------------------------------------
      match /fcmTokens/{tokenId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // -----------------------------------------------------------------
    // conversations/{cid} — chat 1-a-1 fra due utenti.
    // ID deterministico: hash dei due uid ordinati alfabeticamente.
    // Solo i partecipanti possono leggere/scrivere la conversazione e
    // i suoi messaggi.
    // -----------------------------------------------------------------
    match /conversations/{cid} {
      // Get: il doc potrebbe non esistere ancora (find-or-create flow:
      // l'app fa un get prima di creare, per scoprire se la conversazione
      // 1-a-1 esiste già). In quel caso `resource` è null e la regola
      // deve permettere la lettura — non c'è dato da proteggere. Se
      // invece il doc esiste, l'utente deve essere fra i participants.
      allow get: if request.auth != null
                 && (resource == null
                     || request.auth.uid in resource.data.participants);
      // List (query whereField participants arrayContains): basta essere
      // autenticati — la query stessa filtra per arrayContains uid.
      allow list: if request.auth != null;

      // Create: l'utente che crea deve essere fra i participants.
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants is list
                    && request.resource.data.participants.size() == 2;

      // Update: solo participants. Non permettiamo di cambiare la
      // composizione dei participants (l'array deve restare invariato).
      // Tutto il resto è libero, inclusi:
      //   - lastMessage / lastSenderId / updatedAt (aggiornati a ogni
      //     send dal batch di sendMessage)
      //   - hiddenFor: array di uid che hanno "eliminato" la chat dalla
      //     loro lista (soft-delete per partecipante). Si modifica via
      //     arrayUnion (delete) e arrayRemove (riceve nuovo messaggio).
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants
                    && request.resource.data.participants == resource.data.participants;

      // Delete: non supportato.
      allow delete: if false;

      // Sub-collection messaggi
      match /messages/{messageId} {
        // Read solo per participants della conversazione parent.
        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/conversations/$(cid))
                       .data.participants;

        // Create: l'utente deve essere participant E mittente del messaggio.
        allow create: if request.auth != null
                      && request.auth.uid in
                         get(/databases/$(database)/documents/conversations/$(cid))
                         .data.participants
                      && request.resource.data.senderId == request.auth.uid;

        allow update, delete: if false;
      }
    }

    // -----------------------------------------------------------------
    // posts — feed pubblico fra utenti autenticati.
    //         Solo l'autore può creare/modificare/cancellare il proprio post.
    // -----------------------------------------------------------------
    match /posts/{postId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.authorId is string
                    && request.auth.uid == request.resource.data.authorId;

      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.authorId;

      // -------------------------------------------------------------
      // posts/{postId}/likes/{userId} — chi ha messo like al post.
      // ID del documento = uid del liker (idempotenza nativa: ri-tappare
      // like sovrascrive lo stesso doc; togliere like cancella il doc).
      // Payload: { likedAt: Timestamp }.
      //
      // - read: tutti gli utenti loggati (per contare i like e mostrare
      //   la lista likers nello sheet del feed).
      // - create: solo l'utente loggato sul proprio doc, con `likedAt`
      //   come timestamp.
      // - delete: solo il proprietario del like (l'utente loggato sul
      //   proprio doc).
      // - update: vietato — il payload è statico, non c'è motivo di
      //   modificarlo. Per "ri-likare" usiamo set/delete.
      // -------------------------------------------------------------
      match /likes/{userId} {
        allow read:   if request.auth != null;
        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.likedAt is timestamp;
        allow delete: if request.auth != null
                      && request.auth.uid == userId;
        allow update: if false;
      }
    }

    // -----------------------------------------------------------------
    // libraryItems — libreria personale (News / Sport).
    //                Visibile e modificabile SOLO dal proprietario.
    //
    // IMPORTANTE: per le query Firestore (es. snapshot listener con
    // .whereField("ownerId", isEqualTo: uid)) il rules engine valuta la
    // regola contro `resource.data` di OGNI documento che la query
    // potenzialmente restituirebbe. Se la query non è "vincolata" in modo
    // tale che TUTTI i doc rispettino la regola, Firestore la nega upfront.
    // Visto che il client filtra sempre per `ownerId == uid`, la condizione
    // `request.auth.uid == resource.data.ownerId` è soddisfatta per
    // costruzione, e la query è ammessa.
    //
    // NOTA STORICA: in passato qui c'era
    //   `allow list: if request.auth != null && request.query.filters.size() > 0;`
    // ma `request.query` espone SOLO `limit`, `offset` e `orderBy` — NON
    // ha un campo `filters`. L'accesso a `.filters` causava un errore di
    // valutazione CEL e la regola negava ogni listener real-time su
    // News/Sport. Sostituita con il check ownership che è anche più
    // sicuro (non basta che la query abbia un filtro qualunque: deve
    // essere proprio `ownerId == auth.uid`).
    // -----------------------------------------------------------------
    match /libraryItems/{itemId} {
      // Sia get singolo che query (list): in entrambi i casi richiediamo
      // che il documento (o ognuno dei doc restituiti dalla query) abbia
      // ownerId == uid dell'utente loggato. Per le query questo costringe
      // il client a filtrare per ownerId == uid, garantendo la privacy.
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.ownerId;

      allow create: if request.auth != null
                    && request.resource.data.ownerId is string
                    && request.auth.uid == request.resource.data.ownerId;

      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.ownerId;
    }
  }
}
